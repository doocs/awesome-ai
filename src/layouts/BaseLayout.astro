---
import { t, getLocaleFromUrl } from "../i18n/utils.ts";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  locale?: "zh" | "en";
  url?: URL;
}

const { title, description, locale = "zh", url } = Astro.props;
const siteName = t("site.name", locale);
const fullTitle = title !== siteName ? `${title} | ${siteName}` : title;
const desc = description || t("site.tagline", locale);
const currentUrl = url || Astro.url;
const currentLocale = getLocaleFromUrl(currentUrl);
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>" />
    <title>{fullTitle}</title>
    <!-- Theme init: must run before render to prevent flash -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'light' || (stored !== 'dark' && !prefersDark)) {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-bg text-text font-sans antialiased flex flex-col min-h-screen">
    <NavBar locale={currentLocale} currentPath={currentUrl?.pathname || "/"} />

    <main class="max-w-[1100px] mx-auto px-4 sm:px-6 pt-[72px] sm:pt-[80px] pb-[40px] sm:pb-[60px] flex-1 w-full">
      <slot />
    </main>

    <Footer />
  </body>
</html>
