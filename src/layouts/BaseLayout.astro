---
import { t, getLocaleFromUrl } from "../i18n/utils.ts";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import Head from "../components/Head.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  locale?: "zh" | "en";
  url?: URL;
}

const { title, description, locale = "zh", url } = Astro.props;
const siteName = t("site.name", locale);
const fullTitle = title !== siteName ? `${title} | ${siteName}` : title;
const desc = description || t("site.tagline", locale);
const currentUrl = url || Astro.url;
const currentLocale = getLocaleFromUrl(currentUrl);
---

<Head title={fullTitle} description={desc} lang={currentLocale}>
  <slot name="extra">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  </slot>
  <NavBar locale={currentLocale} currentPath={currentUrl?.pathname || "/"} />

  <main class="max-w-[1100px] mx-auto px-4 sm:px-6 pt-[72px] sm:pt-[80px] pb-[40px] sm:pb-[60px] flex-1 w-full">
    <slot />
  </main>

  <Footer />
</Head>
