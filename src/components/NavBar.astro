---
interface Props {
  locale: "zh" | "en";
  currentPath: string;
}

const { locale = "zh", currentPath = "/" } = Astro.props;
import { t } from "../i18n/utils.ts";

const links = locale === "en"
  ? [
      { label: t("nav.home", "en"), href: "/en/", active: currentPath === "/en/" || currentPath === "/en" },
      { label: t("nav.industry", "en"), href: "/en/industry", active: currentPath.startsWith("/en/daily") || currentPath.startsWith("/en/weekly") || currentPath.startsWith("/en/industry") },
      { label: t("nav.topics", "en"), href: "/en/topics", active: currentPath.startsWith("/en/topics") },
      { label: t("nav.rankings", "en"), href: "/en/ai", active: currentPath.startsWith("/en/ai") },
    ]
  : [
      { label: t("nav.home"), href: "/", active: currentPath === "/" },
      { label: t("nav.industry"), href: "/industry", active: currentPath.startsWith("/daily") || currentPath.startsWith("/weekly") || currentPath.startsWith("/industry") },
      { label: t("nav.topics"), href: "/topics", active: currentPath.startsWith("/topics") },
      { label: t("nav.rankings"), href: "/ai", active: currentPath.startsWith("/ai") },
    ];

const langSwitch = locale === "en"
  ? { label: t("nav.lang_cn", "en"), href: currentPath.startsWith("/en/ai") ? "/ai" : currentPath.startsWith("/en/topics") ? "/topics" : currentPath.startsWith("/en/daily") || currentPath.startsWith("/en/industry") ? "/industry" : currentPath.startsWith("/en/weekly") ? "/weekly" : "/" }
  : { label: t("nav.lang_en"), href: currentPath.startsWith("/ai") ? "/en/ai" : currentPath.startsWith("/topics") ? "/en/topics" : currentPath.startsWith("/daily") || currentPath.startsWith("/industry") ? "/en/industry" : currentPath.startsWith("/weekly") ? "/en/weekly" : "/en" };
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-nav backdrop-blur-xl border-b border-border">
  <div class="max-w-[1100px] mx-auto px-4 sm:px-6 h-[56px] sm:h-[60px] flex items-center justify-between">
    <a href={locale === "en" ? "/en/" : "/"} class="text-lg sm:text-xl font-bold flex items-center gap-2 text-text no-underline">
      <span class="text-accent">⚡</span> Awesome AI
    </a>

    <button id="menu-btn" class="sm:hidden p-1.5 -mr-1 rounded-lg text-text-dim hover:text-text transition-colors" aria-label="Menu">
      <svg id="menu-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      <svg id="menu-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <div class="hidden sm:flex items-center gap-1">
      {links.map(link => (
        <a href={link.href}
           class={`px-3 py-1.5 rounded-lg text-sm transition-all ${link.active ? "text-text bg-accent-glow" : "text-text-dim hover:text-text hover:bg-accent-glow"}`}>
          {link.label}
        </a>
      ))}
      <a href={locale === "en" ? "/en/search" : "/search"}
         class="flex items-center gap-1.5 text-text-dim no-underline px-3 py-1.5 rounded-lg text-sm hover:text-text hover:bg-accent-glow transition-all ml-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span class="hidden lg:inline">{t("nav.search_label", locale)}</span>
      </a>
      <a href="https://github.com/doocs/awesome-ai" target="_blank" rel="noopener"
         class="flex items-center gap-1.5 text-text-dim no-underline px-3 py-1.5 rounded-lg text-sm hover:text-text hover:bg-accent-glow transition-all">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;display:block">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        <span>GitHub</span>
      </a>
      <!-- Theme toggle button -->
      <button id="theme-toggle" class="flex items-center justify-center w-8 h-8 rounded-lg text-text-dim hover:text-text hover:bg-accent-glow transition-all" title={locale === "en" ? "Toggle theme" : "切换主题"} aria-label={locale === "en" ? "Toggle theme" : "切换主题"}>
        <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      </button>
      <a href={langSwitch.href}
         class="ml-0.5 px-2 py-1 rounded text-xs text-text-muted hover:text-text hover:bg-accent-glow transition-all">
        {langSwitch.label}
      </a>
    </div>
  </div>

  <div id="mobile-menu" class="sm:hidden hidden border-t border-border bg-bg-nav">
    <div class="px-4 py-3 space-y-0.5">
      {links.map(link => (
        <a href={link.href}
           class={`block px-3 py-2 rounded-lg text-sm transition-all ${link.active ? "text-text bg-accent-glow" : "text-text-dim hover:text-text hover:bg-accent-glow"}`}>
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-4 pt-3 border-t border-border mt-3">
        <a href={locale === "en" ? "/en/search" : "/search"}
           class="flex items-center gap-1.5 text-text-dim no-underline text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          {t("nav.search_label", locale)}
        </a>
        <a href="https://github.com/doocs/awesome-ai" target="_blank" rel="noopener"
           class="flex items-center gap-1.5 text-text-dim no-underline text-sm">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;display:block">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <button id="mobile-theme-toggle" class="flex items-center gap-1.5 text-text-dim text-sm hover:text-text" aria-label={locale === "en" ? "Toggle theme" : "切换主题"}>
          <svg class="mobile-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="mobile-icon-sun hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span class="mobile-theme-label">{locale === "en" ? "Toggle theme" : "切换主题"}</span>
        </button>
        <a href={langSwitch.href}
           class="text-sm text-text-muted hover:text-text">
          {langSwitch.label}
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  var btn = document.getElementById('menu-btn');
  var menu = document.getElementById('mobile-menu');
  var openIcon = document.getElementById('menu-open');
  var closeIcon = document.getElementById('menu-close');
  if (btn && menu) {
    btn.addEventListener('click', function() {
      var isHidden = menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden', !isHidden);
      closeIcon.classList.toggle('hidden', isHidden);
    });
    menu.addEventListener('click', function(e) {
      if (e.target.tagName === 'A') {
        menu.classList.add('hidden');
        openIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      }
    });
  }
  // Ctrl+K or Cmd+K to go to search page
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      window.location.href = window.location.pathname.startsWith('/en') ? '/en/search' : '/search';
    }
  });
  // Theme toggle logic
  var moonIcon = document.getElementById('icon-moon');
  var sunIcon = document.getElementById('icon-sun');
  var mobileMoonIcon = document.querySelector('.mobile-icon-moon');
  var mobileSunIcon = document.querySelector('.mobile-icon-sun');
  var mobileThemeLabel = document.querySelector('.mobile-theme-label');
  var themeLabel = document.documentElement.lang === 'en' ? 'Toggle theme' : '切换主题';
  function updateIcons(isDark) {
    if (isDark) {
      moonIcon.classList.add('hidden');
      sunIcon.classList.remove('hidden');
      if (mobileMoonIcon) mobileMoonIcon.classList.add('hidden');
      if (mobileSunIcon) mobileSunIcon.classList.remove('hidden');
      if (mobileThemeLabel) mobileThemeLabel.textContent = themeLabel;
    } else {
      moonIcon.classList.remove('hidden');
      sunIcon.classList.add('hidden');
      if (mobileMoonIcon) mobileMoonIcon.classList.remove('hidden');
      if (mobileSunIcon) mobileSunIcon.classList.add('hidden');
      if (mobileThemeLabel) mobileThemeLabel.textContent = themeLabel;
    }
  }
  function toggleTheme() {
    var isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateIcons(isDark);
  }
  var themeToggle = document.getElementById('theme-toggle');
  var mobileThemeToggle = document.getElementById('mobile-theme-toggle');
  if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
  if (mobileThemeToggle) mobileThemeToggle.addEventListener('click', toggleTheme);
  // Set initial icon state
  var isDark = document.documentElement.classList.contains('dark');
  updateIcons(isDark);
  // Listen for system theme changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
    if (!localStorage.getItem('theme')) {
      if (e.matches) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      updateIcons(e.matches);
    }
  });
</script>
