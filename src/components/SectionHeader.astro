---
/**
 * Reusable section heading with accent bar + title + "more" link.
 * Matches the pattern used on the homepage and listing pages.
 */
interface Props {
  title: string;
  href: string;
  accentColor?: "accent" | "pink";
  locale?: "zh" | "en";
}

const { title, href, accentColor = "accent", locale = "zh" } = Astro.props;
import { t } from "../i18n/utils.ts";
const accentClass = accentColor === "pink" ? "bg-pink" : "bg-accent";
---

<div class="flex items-center justify-between mb-4 sm:mb-5">
  <h2 class="text-lg sm:text-xl font-semibold flex items-center gap-2">
    <span class={`w-1 h-5 ${accentClass} rounded-full`}></span>
    {title}
  </h2>
  <a href={href} class="text-sm text-text-muted hover:text-accent-light transition-colors no-underline">
    <slot name="more">{t("home.more", locale)}</slot>
  </a>
</div>
