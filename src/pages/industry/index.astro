---
import NavBar from "../../components/NavBar.astro";
import Head from "../../components/Head.astro";
import Footer from "../../components/Footer.astro";
import Card from "../../components/Card.astro";
import "../../styles/global.css";
import { t } from "../../i18n/utils.ts";
import { getCollection } from "astro:content";
import { extractSummary, extractTags, TAG_MAP_ZH, formatDateCn, formatWeekDate } from "../../lib/content.ts";

const allDaily = await getCollection("daily");
const allWeekly = await getCollection("weekly");





const items = [
  ...allDaily.map(a => ({
    type: "daily" as const,
    title: a.data.title,
    date: formatDateCn(a.data.date),
    dateRaw: a.data.date,
    summary: extractSummary(a.body),
    tags: extractTags(a.body, TAG_MAP_ZH),
    href: `/daily/${a.id.replace(".md", "")}`,
  })),
  ...allWeekly.map(a => ({
    type: "weekly" as const,
    title: a.data.title,
    date: formatWeekDate(a.data.date),
    dateRaw: a.data.date,
    summary: extractSummary(a.body),
    tags: extractTags(a.body, TAG_MAP_ZH),
    href: `/weekly/${a.id.replace(".md", "")}`,
  })),
].sort((a, b) => b.dateRaw.localeCompare(a.dateRaw));
---

<Head title={`${t("page.title_industry")} | Awesome AI`} lang="zh">
  <NavBar locale="zh" currentPath="/industry" />
    <main class="max-w-[1100px] mx-auto px-4 sm:px-6 pt-[72px] sm:pt-[80px] pb-[40px] sm:pb-[60px] flex-1 w-full">
      <div class="grid gap-3 sm:gap-4">
        {items.map((item) => (
          <Card
            type={item.type}
            title={item.title}
            date={item.date}
            summary={item.summary}
            tags={item.tags}
            href={item.href}
          />
        ))}
      </div>
    </main>
    <Footer locale="zh" />
</Head>
