---
import NavBar from "../../components/NavBar.astro";
import Head from "../../components/Head.astro";
import Footer from "../../components/Footer.astro";
import Card from "../../components/Card.astro";
import "../../styles/global.css";
import { t } from "../../i18n/utils.ts";
import { getCollection } from "astro:content";
import { extractSummary, extractTags, TAG_MAP_ZH, formatWeekDate } from "../../lib/content.ts";

const allWeekly = await getCollection("weekly");
const sorted = allWeekly.sort((a, b) => b.data.date.localeCompare(a.data.date));



---

<Head title={`${t("page.title_weekly")} | Awesome AI`} lang="zh">
  <NavBar locale="zh" currentPath="/weekly" />
    <main class="max-w-[1100px] mx-auto px-4 sm:px-6 pt-[72px] sm:pt-[80px] pb-[40px] sm:pb-[60px] flex-1 w-full">
      <div class="grid gap-3 sm:gap-4">
        {sorted.map((article) => (
          <Card type="weekly" title={article.data.title} date={formatWeekDate(article.data.date)} summary={extractSummary(article.body)} tags={extractTags(article.body, TAG_MAP_ZH)} href={`/weekly/${article.id.replace(".md", "")}`} />
        ))}
      </div>
    </main>
    <Footer />
</Head>
