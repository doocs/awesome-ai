---
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import Head from "../../components/Head.astro";
import Card from "../../components/Card.astro";
import "../../styles/global.css";
import { t } from "../../i18n/utils.ts";
import { getCollection } from "astro:content";
import { extractSummary, extractTags, TAG_MAP_ZH, formatDateCn } from "../../lib/content.ts";

const allDaily = await getCollection("daily");
const sorted = allDaily.sort((a, b) => b.data.date.localeCompare(a.data.date));



---

<Head title={t("page.title_daily")} lang="zh">
  <NavBar locale="zh" currentPath="/daily" />
  <main class="max-w-[1100px] mx-auto px-4 sm:px-6 pt-[72px] sm:pt-[80px] pb-[40px] sm:pb-[60px] flex-1 w-full">
    <div class="grid gap-3 sm:gap-4">
      {sorted.map((article) => (
        <Card type="daily" title={article.data.title} date={formatDateCn(article.data.date)} summary={extractSummary(article.body)} tags={extractTags(article.body, TAG_MAP_ZH)} href={`/daily/${article.id.replace(".md", "")}`} />
      ))}
    </div>
  </main>
  <Footer />
</Head>
